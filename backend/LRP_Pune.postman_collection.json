						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"superadmin@lrppune.org\",\n    \"password\": \"securepassword456\",\n    \"role\": \"SUPER_ADMIN\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/admin/",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"admin",
								""
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Upload Metrics",
			"item": [
				{
					"name": "Upload Report PDF",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "file",
									"type": "file",
									"src": []
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/api/upload",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"upload"
							]
						},
						"description": "Upload a PDF Metro report to be automatically parsed by the Gemini model and synchronized with the database. To test, attach a sample report PDF in the 'file' field above."
					},
					"response": []
				}
			]
		},
		{
			"name": "Pillars",
			"item": [
