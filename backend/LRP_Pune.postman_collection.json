						"method": "PUT",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"key\": \"Households Supported\",\n    \"value\": \"2000\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/pillars/1",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"pillars",
								"1"
							]
						}
					},
					"response": []
