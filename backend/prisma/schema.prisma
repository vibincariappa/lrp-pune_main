generator client {
 provider = "prisma-client-js"
 output   = "../node_modules/@prisma/client/.prisma/client"
}

datasource db {
 provider = "postgresql"
}

model Admin {
  id           String @id @default(uuid())
  email        String @unique
  username     String @unique
  passwordHash String
  role         String
  isActive     Boolean @default(true)
  lastLogin    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
  loginAudits  LoginAudit[]
}

model LoginAudit {
  id        String   @id @default(uuid())
  adminId   String
  ipAddress String?
  userAgent String?
  loginTime DateTime @default(now())
  success   Boolean
  admin     Admin    @relation(fields: [adminId], references: [id])
}

model PillarData {
  id        String   @id @default(uuid())

  pillar    Int

  key       String

  value     String

  updatedAt DateTime @updatedAt

  @@unique([pillar,key])
}

model UploadLog {

  id          String @id @default(uuid())

  filename    String

  storagePath String

  status      UploadStatus

  createdAt   DateTime @default(now())

}

enum UploadStatus {

  PROCESSING

  COMPLETED

  FAILED

}