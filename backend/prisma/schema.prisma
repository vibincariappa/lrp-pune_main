generator client {
 provider = "prisma-client-js"
 output   = "../node_modules/@prisma/client/.prisma/client"
}

datasource db {
 provider = "postgresql"
}

model Admin {
 id           String @id @default(uuid())
 email        String @unique
 passwordHash String
 role         String @default("EDITOR")
}

model PillarData {
  id        String   @id @default(uuid())

  pillar    Int

  key       String

  value     String

  updatedAt DateTime @updatedAt

  @@unique([pillar,key])
}

model UploadLog {

  id          String @id @default(uuid())

  filename    String

  storagePath String

  status      UploadStatus

  createdAt   DateTime @default(now())

}

enum UploadStatus {

  PROCESSING

  COMPLETED

  FAILED

}